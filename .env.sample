# Registration service
ADMIN_USERNAME=adminuser
ADMIN_PASSWORD=adminpassword

# Server address (IP or domain)
# Leave empty to auto-detect server IP at startup
# Set explicitly to override: 192.168.1.100, music.example.com, etc.
SERVER_ADDRESS=

# Navidrome service
ND_SCANSCHEDULE=1h
ND_LOGLEVEL=info
ND_ENABLEEXTERNALSERVICES=false
ND_ENABLEDOWNLOADS=true
ND_ENABLESHARING=false

# Caddy published ports
HTTP_PORT=80
HTTPS_PORT=443
TLS_INTERNAL=true
CF_API_TOKEN=