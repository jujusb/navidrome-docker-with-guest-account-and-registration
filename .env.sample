# Registration service
ADMIN_USERNAME=adminuser
ADMIN_PASSWORD=adminpassword

MULTIPLE_CADDY_GLOBAL=false

# Server address (IP or domain)
# Leave empty to auto-detect server IP at startup
# Set explicitly to override: 192.168.1.100, music.example.com, etc.
MUSIC_SERVER_ADDRESS=

# Paths for music data and Navidrome database
MUSIC_DATA_PATH=./music
DOCKER_DATA_PATH=./docker/data

# Navidrome service
ND_SCANSCHEDULE=1h
ND_LOGLEVEL=info
ND_ENABLEEXTERNALSERVICES=false
ND_ENABLEDOWNLOADS=true
ND_ENABLESHARING=false

# Caddy published ports
HTTP_PORT=80
HTTPS_PORT=443
CF_API_TOKEN=

GUEST_EXPIRATION_HOURS=24 # Automatically remove guest users after this many hours (default: 1)