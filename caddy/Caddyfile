:80 {	
	# Block downloads for guest users before requests are proxied.
	@guestDownload {
		path /rest/download.view
		header Cookie *guest*
	}
	respond @guestDownload 403 "Downloads are not allowed for guest users"

	# Serve the registration page only on the root URL.
	@rootOnly path /
	handle @rootOnly {
		root * /usr/share/caddy
		try_files /index.html
		file_server
	}

	@registrationApi path /register /register/*
	handle @registrationApi {
		reverse_proxy navidrome-registration:3000
	}

	@guestApi path /guest /guest/*
	handle @guestApi {
		reverse_proxy navidrome-registration:3000
	}

	# Explicit Navidrome routes.
	handle /rest/* {
		reverse_proxy navidrome:4533
	}

	handle /app/* {
		reverse_proxy navidrome:4533
	}

	handle /static/* {
		reverse_proxy navidrome:4533
	}

	handle /favicon.ico {
		reverse_proxy navidrome:4533
	}

	# Fallback for other Navidrome endpoints ("etc.").
	handle {
		reverse_proxy navidrome:4533
	}
}
